func sumaLista(nums: list<int>): int {
    let i: int = 0;
    let total: int = 0;

    while (i < len(nums)) {
        total = total + nums[i];
        i = i + 1;
    }

    return total;
}

func promedioLista(nums: list<int>): float {
    if (len(nums) == 0) {
        return 0;
    }

    return sumaLista(nums) / len(nums);
}

func maximo(a: int, b: int): int {
    if (a >= b) {
        return a;
    }
    return b;
}
