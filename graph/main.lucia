import "graph.lucia";

let graph: Graph = Graph();

graph.addNode("A");
graph.addNode("B");
graph.addNode("C");
graph.addNode("D");

graph.connect("A","B");
graph.connect("A","C");
graph.connect("B","D");

let nodeA: Node = graph.findNode("A");

if (nodeA != null) {
    print("Node found:");
    print(nodeA.id);

    print("Neighbors of A:");
    for (neighbor in nodeA.neighbors) {
        print(neighbor.id);
    }
}
